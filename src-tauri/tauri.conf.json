{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Simplevoice",
  "version": "0.1.6",
  "identifier": "com.woro.simplevoice",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Simplevoice",
        "width": 1040,
        "height": 700,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximizable": true,
        "decorations": false,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "shortDescription": "Privacy-first, local & offline Speech-to-Text and voice typing.",
    "longDescription": "Simplevoice is a privacy-first Speech-to-Text desktop assistant that runs fully local and offline. Record system audio, transcribe with local ASR engines, and auto-paste or copy the result — no cloud, no telemetry.",
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": {
      "sounds/*": "sounds/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/MaciejKolerski/simplevoice/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxNTgzRUNFRDYwQzM3NUQKUldSZE53eld6ajVZd1hpWXNxZkduOGVMeFRxTzRTV0JFU1I4ZGJLcDc5ay83WnlzOEE1dnN0djkK"
    }
  }
}
